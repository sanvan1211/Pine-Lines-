ta.rsi(source, length)   <span class="comment">// relative strength index</span>
ta.macd(source, length)  <span class="comment">// moving average convergence divergence</span>
ta.atr(length)           <span class="comment">// average true range</span>

<span class="comment">// mathematical functions</span>
